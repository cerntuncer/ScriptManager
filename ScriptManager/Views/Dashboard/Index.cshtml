@model ScriptManager.Models.Dashboard.DashboardViewModel

@{
    var total = Model.TotalScripts;
    Func<int, double> pctD = n => total > 0 ? Math.Round(n * 100.0 / total, 1) : 0;
    Func<int, int> pct = n => total > 0 ? (int)Math.Round(n * 100.0 / total) : 0;
    var latestVer = Model.LatestReleases.FirstOrDefault()?.Version ?? "—";

    @* conic-gradient cumulative stops — palette: sky / indigo / rose / slate *@
    var s1 = pctD(Model.ReadyScripts);
    var s2 = s1 + pctD(Model.DraftScripts);
    var s3 = s2 + pctD(Model.OpenConflicts);
    string Fmt(double v) => v.ToString("F1", System.Globalization.CultureInfo.InvariantCulture);
    var conicBg = total == 0
        ? "conic-gradient(#e8eaf3 0% 100%)"
        : $"conic-gradient(#0ea5e9 0% {Fmt(s1)}%, #6366f1 {Fmt(s1)}% {Fmt(s2)}%, #f43f5e {Fmt(s2)}% {Fmt(s3)}%, #94a3b8 {Fmt(s3)}% 100%)";
}

<div class="dash-page-head">
    <div>
        <h1 class="page-title">Genel Bakış</h1>
        <p class="page-subtitle">Script ve sürüm durumlarının özeti</p>
    </div>
</div>

<div class="dash-kpi-row">
    <div class="dash-kpi-card">
        <div class="dash-kpi-icon dash-kpi-icon--blue">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
        </div>
        <div class="dash-kpi-body">
            <span class="dash-kpi-label">Toplam Script</span>
            <span class="dash-kpi-value">@Model.TotalScripts</span>
            <span class="dash-kpi-sub">@Model.ReadyScripts hazır · @Model.DraftScripts taslak</span>
        </div>
    </div>

    <div class="dash-kpi-card">
        <div class="dash-kpi-icon dash-kpi-icon--purple">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
        </div>
        <div class="dash-kpi-body">
            <span class="dash-kpi-label">Toplam Sürüm</span>
            <span class="dash-kpi-value">@Model.TotalReleases</span>
            <span class="dash-kpi-sub">Son: @latestVer</span>
        </div>
    </div>

    <div class="dash-kpi-card @(Model.ReadyScripts > 0 ? "dash-kpi-card--success" : "")">
        <div class="dash-kpi-icon dash-kpi-icon--green">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div class="dash-kpi-body">
            <span class="dash-kpi-label">Hazır</span>
            <span class="dash-kpi-value">@Model.ReadyScripts</span>
            <span class="dash-kpi-sub">Sürüme eklenebilir</span>
        </div>
    </div>

    <div class="dash-kpi-card @(Model.OpenConflicts > 0 ? "dash-kpi-card--danger" : "")">
        <div class="dash-kpi-icon dash-kpi-icon--red">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        </div>
        <div class="dash-kpi-body">
            <span class="dash-kpi-label">Açık Çakışma</span>
            <span class="dash-kpi-value @(Model.OpenConflicts > 0 ? "text-danger-val" : "")">@Model.OpenConflicts</span>
            <span class="dash-kpi-sub">@(Model.OpenConflicts > 0 ? "Çözüm gerekiyor" : "Sorun yok")</span>
        </div>
    </div>
</div>

<div class="dash-main-grid">

    <div class="panel-card dash-chart-panel">
        <div class="panel-header">
            <h3>Script Dağılımı</h3>
            @if (total > 0)
            {
                <span class="dash-total-badge">@total script</span>
            }
        </div>

        @if (total == 0)
        {
            <div class="dash-empty">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity=".3"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/></svg>
                <p>Henüz script yok</p>
            </div>
        }
        else
        {
            <div class="dash-chart-inner">
                @* Donut Chart *@
                <div class="donut-wrap">
                    <div class="donut-ring" style="background: @conicBg">
                        <div class="donut-hole">
                            <span class="donut-num">@total</span>
                            <span class="donut-lbl">Script</span>
                        </div>
                    </div>
                </div>

                @* Legend rows *@
                <div class="dash-dist-list">
                    <div class="dash-dist-row">
                        <span class="dash-dist-dot dash-dist-dot--ready"></span>
                        <span class="dash-dist-name">Hazır</span>
                        <div class="dash-dist-track">
                            <div class="dash-dist-fill dash-dist-fill--ready" style="width:@(pct(Model.ReadyScripts))%"></div>
                        </div>
                        <span class="dash-dist-count">@Model.ReadyScripts</span>
                        <span class="dash-dist-pct">%@pct(Model.ReadyScripts)</span>
                    </div>
                    <div class="dash-dist-row">
                        <span class="dash-dist-dot dash-dist-dot--draft"></span>
                        <span class="dash-dist-name">Taslak</span>
                        <div class="dash-dist-track">
                            <div class="dash-dist-fill dash-dist-fill--draft" style="width:@(pct(Model.DraftScripts))%"></div>
                        </div>
                        <span class="dash-dist-count">@Model.DraftScripts</span>
                        <span class="dash-dist-pct">%@pct(Model.DraftScripts)</span>
                    </div>
                    <div class="dash-dist-row">
                        <span class="dash-dist-dot dash-dist-dot--conflict"></span>
                        <span class="dash-dist-name">Çakışma</span>
                        <div class="dash-dist-track">
                            <div class="dash-dist-fill dash-dist-fill--conflict" style="width:@(pct(Model.OpenConflicts))%"></div>
                        </div>
                        <span class="dash-dist-count">@Model.OpenConflicts</span>
                        <span class="dash-dist-pct">%@pct(Model.OpenConflicts)</span>
                    </div>
                    @if (Model.OtherScripts > 0)
                    {
                        <div class="dash-dist-row">
                            <span class="dash-dist-dot dash-dist-dot--other"></span>
                            <span class="dash-dist-name">Diğer</span>
                            <div class="dash-dist-track">
                                <div class="dash-dist-fill dash-dist-fill--other" style="width:@(pct(Model.OtherScripts))%"></div>
                            </div>
                            <span class="dash-dist-count">@Model.OtherScripts</span>
                            <span class="dash-dist-pct">%@pct(Model.OtherScripts)</span>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    <div class="panel-card dash-releases-panel">
        <div class="panel-header">
            <h3>Son Sürümler</h3>
            <a href="@Url.Action("Index", "Releases")" class="dash-see-all">Tümünü gör →</a>
        </div>

        @if (!Model.LatestReleases.Any())
        {
            <div class="dash-empty">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity=".3"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                <p>Henüz sürüm yok</p>
            </div>
        }
        else
        {
            <div class="dash-release-list">
                @foreach (var item in Model.LatestReleases)
                {
                    <a class="dash-release-row" href="@Url.Action("Detail", "Releases", new { id = item.ReleaseId })">
                        <div class="dash-ver-badge @(item.IsCancelled ? "dash-ver-badge--cancelled" : "")">
                            @item.Version
                        </div>
                        <div class="dash-release-info">
                            <span class="dash-release-name">@item.Name</span>
                            <span class="dash-release-date">@item.CreatedAt.ToString("dd MMM yyyy")</span>
                        </div>
                        <div class="dash-release-stats">
                            <span class="dash-rel-stat" title="Script sayısı">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/></svg>
                                @item.ScriptCount
                            </span>
                            @if (item.RollbackScriptCount > 0)
                            {
                                <span class="dash-rel-stat dash-rel-stat--rb" title="Rollback sayısı">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.51"/></svg>
                                    @item.RollbackScriptCount
                                </span>
                            }
                        </div>
                        <svg class="dash-release-chevron" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
                    </a>
                }
            </div>
        }
    </div>

</div>
