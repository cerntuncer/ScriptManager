@model ScriptManager.Models.Batch.PoolBatchTreeNodeDto
@{
    var canWrite = ViewBag.CanWrite as bool? == true;
    var hasCh = Model.Children.Count > 0;
    var safeNameJs = Model.Name.Replace("\\", "\\\\").Replace("'", "\\'");
    var canInteract = canWrite && !Model.IsLocked;
    var linkedReleaseIdJs = Model.LinkedReleaseId.HasValue ? Model.LinkedReleaseId.Value.ToString() : "0";
    var isLinked = !string.IsNullOrEmpty(Model.LinkedReleaseVersion);
}

<li class="vtree-item">
    <div class="vtree-row">
        @if (hasCh)
        {
            <button type="button" class="vtree-toggle" onclick="vtreeToggle(this)" title="Aç / kapat" aria-expanded="false">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5l8 7-8 7"/></svg>
            </button>
        }
        else
        {
            <span class="vtree-toggle vtree-toggle--leaf"></span>
        }

        @if (canInteract)
        {
            <div class="vtree-label vtree-label--clickable"
                 onclick="openFolderActionModal(@Model.BatchId, '@Html.Raw(safeNameJs)', true, true, @linkedReleaseIdJs)">

                @if (isLinked)
                {
                    <svg class="vtree-icon vtree-icon--linked" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
                }
                else
                {
                    <svg class="vtree-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
                }

                <span class="vtree-name">@Model.Name</span>

                @if (isLinked)
                {
                    <span class="vtree-badge vtree-badge--release">@Model.LinkedReleaseVersion</span>
                }

                <span class="vtree-action-hint">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="5" r="1"/><circle cx="12" cy="12" r="1"/><circle cx="12" cy="19" r="1"/></svg>
                </span>
            </div>
            @if (Model.CanDelete)
            {
                <button type="button" class="vtree-delete-btn"
                        onclick="event.stopPropagation(); deletePoolBatch(@Model.BatchId, '@Html.Raw(safeNameJs)')"
                        title="Versiyonu sil">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                </button>
            }
        }
        else
        {
            <div class="vtree-label">

                <svg class="vtree-icon vtree-icon--locked" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>

                <span class="vtree-name">@Model.Name</span>

                @if (isLinked)
                {
                    <span class="vtree-badge vtree-badge--release">@Model.LinkedReleaseVersion</span>
                }
                <span class="vtree-badge vtree-badge--locked">Kilitli</span>
            </div>
        }
    </div>

    @if (hasCh)
    {
        <ul class="vtree-children vtree-children--hidden list-unstyled">
            @foreach (var c in Model.Children)
            {
                <partial name="_PoolBatchTreeNode" model="c" />
            }
        </ul>
    }
</li>
