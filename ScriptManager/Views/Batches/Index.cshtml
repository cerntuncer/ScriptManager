@model List<ScriptManager.Models.Batch.PoolBatchTreeNodeDto>
@using System.Text.Json
@{
    var canWrite = ViewBag.CanWrite as bool? == true;
    var devs = ViewBag.Developers as IEnumerable<ScriptManager.Models.Script.UserOptionViewModel> ??
               Array.Empty<ScriptManager.Models.Script.UserOptionViewModel>();
    var devJson = JsonSerializer.Serialize(devs.Select(d => new { id = d.UserId, name = d.Name, email = d.Email }));
}

<div class="page-head">
    <div>
        <h1 class="page-title">Versiyonlar</h1>
        <p class="page-sub text-muted mb-0 small">Geliştiricilerin script eklediği çalışma alanı. Sürüme alınana kadar serbestçe düzenlenebilir.</p>
    </div>
    @if (canWrite)
    {
        <div class="page-actions">
            <button type="button" class="btn btn-primary modern-btn text-white" onclick="openPoolRootBatchModal()">Yeni versiyon</button>
        </div>
    }
</div>

<div class="panel-card">
    @if (Model.Count == 0)
    {
        <div class="p-4 text-center text-muted small">
            <svg width="42" height="42" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" opacity=".3" class="mb-2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
            <p class="mb-1 fw-medium">Henüz klasör yok</p>
            <p class="mb-0">Sağ üstten <strong>Yeni klasör</strong> oluşturarak başlayabilirsin.</p>
        </div>
    }
    else
    {
        <ul class="vtree-root list-unstyled mb-0">
            @foreach (var root in Model)
            {
                <partial name="_PoolBatchTreeNode" model="root" />
            }
        </ul>
    }
</div>

@section Scripts {
    <script>
        window.__batchesPageUrls = @Html.Raw(JsonSerializer.Serialize(new {
            index = Url.Action("Index", "Batches"),
            addPoolFolder = Url.Action("AddPoolFolder", "Batches"),
            addReleaseFolder = Url.Action("AddFolder", "Releases"),
            treeChildren = Url.Action("TreeChildren", "Batches"),
            batchPath = Url.Action("BatchPath", "Batches"),
            releaseDetailBase = Url.Action("Detail", "Releases", new { id = 999999999L }).Replace("999999999", ""),
            deletePoolBatch = Url.Action("DeletePoolBatch", "Batches")
        }));
        window.__scriptCreateMeta = { developers: @Html.Raw(devJson) };
        window.__scriptsPageUrls = @Html.Raw(JsonSerializer.Serialize(new {
            createWizardContext = Url.Action("CreateWizardContext", "Scripts"),
            create = Url.Action("Create", "Scripts"),
            validateSql = Url.Action("ValidateSql", "Scripts"),
            batchesIndex = Url.Action("Index", "Batches"),
            developerOptions = Url.Action("DeveloperOptions", "Scripts"),
            addPoolFolder = Url.Action("AddPoolFolder", "Batches"),
            treeChildren = Url.Action("TreeChildren", "Batches"),
            batchPath = Url.Action("BatchPath", "Batches"),
            detailUrlPlaceholder = Url.Action("Detail", "Scripts", new { id = 999999999L }),
            deleteUrlPlaceholder = Url.Action("Delete", "Scripts", new { id = 999999999L })
        }));
    </script>
}
