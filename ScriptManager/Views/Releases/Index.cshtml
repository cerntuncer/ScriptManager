@model ScriptManager.Models.Release.ReleasesIndexViewModel
@using System.Text.Json

@{
    var devJson = JsonSerializer.Serialize(Model.Developers.Select(d => new { id = d.UserId, name = d.Name, email = d.Email }));
    var isAdmin = ViewBag.IsAdmin as bool? == true;
    var canWrite = ViewBag.CanWrite as bool? == true;
}

<div class="page-head">
    <div>
        <h1 class="page-title">Sürümler</h1>
        <p class="page-sub text-muted mb-0 small">Production'a gidecek deployment paketi. Seçilen versiyonlar kilitlenir ve tek bir SQL dosyasına export edilir.</p>
    </div>
    @if (canWrite)
    {
        <div class="page-actions">
            <button type="button" class="btn btn-primary modern-btn text-white" onclick="openCreateReleaseModal()">Yeni sürüm</button>
        </div>
    }
</div>

<div class="panel-card">
    <div class="panel-header">
        <h3 class="mb-0">Sürüm listesi</h3>
    </div>

    <div class="table-toolbar">
        <input id="releaseFilterInput" class="table-filter-input" placeholder="Sürüm ara..." />
    </div>

    <div class="table-wrap custom-scroll">
        <table class="modern-table" id="releaseTable">
            <thead>
                <tr>
                    <th>Durum</th>
                    <th>Sürüm</th>
                    <th>Script</th>
                    <th>Rollback</th>
                    <th>Oluşturulma</th>
                    <th></th>
                </tr>
            </thead>
            <tbody id="releaseTableBody">
                @foreach (var item in Model.Releases)
                {
                    <tr data-release-id="@item.ReleaseId" data-filter-hidden="0">
                        <td>
                            @if (item.IsCancelled)
                            {
                                <span class="badge text-bg-secondary small">İptal</span>
                            }
                            else
                            {
                                <span class="text-muted small">Aktif</span>
                            }
                        </td>
                        <td>@item.Name</td>
                        <td>@item.ScriptCount</td>
                        <td>@item.RollbackScriptCount</td>
                        <td>@item.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>
                            <a class="btn btn-sm btn-table" href="@Url.Action("Detail", "Releases", new { id = item.ReleaseId })">Detay</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        window.__releaseCreateMeta = { developers: @Html.Raw(devJson) };
        window.__releaseCreateUrls = @Html.Raw(JsonSerializer.Serialize(new {
            create = Url.Action("Create", "Releases"),
            developerOptions = Url.Action("DeveloperOptions", "Scripts"),
            treeChildren = Url.Action("TreeChildren", "Batches"),
            detailUrlPlaceholder = Url.Action("Detail", "Releases", new { id = 999999999L }),
            bulkCancel = Url.Action("BulkCancel", "Releases"),
            cancelOne = Url.Action("CancelOne", "Releases")
        }));
    </script>
    <script>
        setupTableFilter("releaseFilterInput", "#releaseTable tbody tr");
        setupPagination("releaseTableBody", 15);
        document.getElementById("releaseSelectAll")?.addEventListener("change", function () {
            const on = this.checked;
            document.querySelectorAll(".release-row-cb").forEach((cb) => (cb.checked = on));
        });

        async function cancelOneRelease(id) {
            const url = window.__releaseCreateUrls?.cancelOne;
            if (!url) { showToast("İptal adresi tanımsız.", "error"); return; }
            if (!confirm("Bu sürüm iptal edilecek; klasörler genel alana döner, kayıt silinmez. Devam?")) return;
            const res = await fetch(url, {
                method: "POST",
                headers: { "Content-Type": "application/json", Accept: "application/json" },
                body: JSON.stringify({ releaseId: id })
            });
            let data = null;
            try { data = await res.json(); } catch (_) {}
            if (!res.ok || data?.success === false) {
                showToast(data?.message || "İptal edilemedi.", "error");
                return;
            }
            showToast(data?.message || "Tamam.", "success");
            const tr = document.querySelector(`tr[data-release-id="${id}"]`);
            if (tr) {
                // Status hücresini güncelle
                const statusTd = Array.from(tr.cells).find(td => td.querySelector(".text-muted.small, .badge"));
                if (statusTd) statusTd.innerHTML = '<span class="badge text-bg-secondary small">İptal</span>';
                // Checkbox'ı kaldır (iptal edilmiş satır seçilemez)
                tr.querySelector(".release-row-cb")?.closest("td")?.replaceChildren();
                // İptal butonunu kaldır
                tr.querySelector(`button[onclick="cancelOneRelease(${id})"]`)?.remove();
            } else {
                window.location.reload();
            }
        }

        async function bulkCancelSelectedReleases() {
            const url = window.__releaseCreateUrls?.bulkCancel;
            if (!url) {
                showToast("Toplu iptal adresi tanımsız.", "error");
                return;
            }
            const ids = Array.from(document.querySelectorAll(".release-row-cb:checked"))
                .map((cb) => Number(cb.value))
                .filter((n) => n > 0);
            if (ids.length === 0) {
                showToast("Sürüm seçin.", "error");
                return;
            }
            if (!confirm(ids.length + " sürüm iptal edilecek; klasörler genel alana döner, kayıt silinmez. Devam?")) return;
            const res = await fetch(url, {
                method: "POST",
                headers: { "Content-Type": "application/json", Accept: "application/json" },
                body: JSON.stringify({ releaseIds: ids })
            });
            let data = null;
            try {
                data = await res.json();
            } catch (_) {}
            if (!res.ok || data?.success === false) {
                showToast(data?.message || "İşlem başarısız.", "error");
                return;
            }
            showToast(data?.message || "Tamam.", "success");
            window.location.reload();
        }
    </script>
}
