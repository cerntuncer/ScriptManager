@model ScriptManager.Models.Script.ScriptsIndexViewModel
@using System.Text.Json
@using ScriptManager.Security
@{
    var canAuthor = ViewBag.CanAuthorScripts as bool? == true;
}

<div class="page-head">
    <div>
        <h1 class="page-title">Scripts</h1>
        <p class="page-sub text-muted mb-0 small">Klasör yapısı <a href="@Url.Action("Index", "Batches")">Klasör Ağacı</a> üzerinden kurulur; script eklerken seçtiğin klasöre doğrudan eklenir. Release için <a href="@Url.Action("Index", "Releases")">Releases</a>.</p>
    </div>
    @if (canAuthor)
    {
        <div class="page-actions">
            <button type="button" class="btn btn-primary modern-btn text-white" onclick="openScriptsPageCreateModal()">Yeni script</button>
        </div>
    }
</div>

<div class="panel-card">
    <div class="panel-header">
        <h3>Script listesi</h3>
    </div>

    <div class="table-toolbar">
        <input id="scriptFilterInput" class="table-filter-input" placeholder="Script ara..." />
    </div>

    <div class="table-wrap custom-scroll">
        <table class="modern-table" id="scriptTable">
            <thead>
                <tr>
                    <th>Ad</th>
                    <th>Durum</th>
                    <th>Batch</th>
                    <th>Geliştirici</th>
                    <th>Rollback</th>
                    <th>Tarih</th>
                    <th></th>
                </tr>
            </thead>
            <tbody id="scriptTableBody">
                @foreach (var item in Model.Scripts)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>@item.StatusDisplay</td>
                        <td>@item.BatchName</td>
                        <td>@item.DeveloperName</td>
                        <td>@(item.HasRollback ? "Var" : "—")</td>
                        <td>@item.CreatedAt.ToString("dd.MM.yyyy")</td>
                        <td class="text-nowrap">
                            <a class="btn btn-sm btn-table" href="@Url.Action("Detail", "Scripts", new { id = item.ScriptId })">Detay</a>
                            @if (AuthHelper.CanDeleteScript(User, item.DeveloperId))
                            {
                                <button type="button" class="btn btn-sm btn-outline-danger"
                                        onclick="deleteScriptFromList(@item.ScriptId, this)">Sil</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        window.__scriptsPageUrls = @Html.Raw(JsonSerializer.Serialize(new {
            createWizardContext = Url.Action("CreateWizardContext", "Scripts"),
            create = Url.Action("Create", "Scripts"),
            batchesIndex = Url.Action("Index", "Batches"),
            developerOptions = Url.Action("DeveloperOptions", "Scripts"),
            addPoolFolder = Url.Action("AddPoolFolder", "Batches"),
            treeChildren = Url.Action("TreeChildren", "Batches"),
            batchPath = Url.Action("BatchPath", "Batches"),
            detailUrlPlaceholder = Url.Action("Detail", "Scripts", new { id = 999999999L }),
            deleteUrlPlaceholder = Url.Action("Delete", "Scripts", new { id = 999999999L })
        }));
        window.__scriptCreateUrls = window.__scriptsPageUrls;
        setupTableFilter("scriptFilterInput", "#scriptTable tbody tr");
    </script>
}
