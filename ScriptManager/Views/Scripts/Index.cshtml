@model ScriptManager.Models.Script.ScriptsIndexViewModel
@using System.Text.Json
@using ScriptManager.Security
@using DAL.Enums
@{
    var canAuthor    = ViewBag.CanAuthorScripts as bool? == true;
    var isAdmin      = ViewBag.IsAdmin as bool? == true;
    var actorUserId  = ViewBag.ActorUserId as long? ?? 0L;
}

<div class="page-head">
    <div>
        <h1 class="page-title">Scriptler</h1>
        <p class="page-sub text-muted mb-0 small">Klasör yapısı <a href="@Url.Action("Index", "Batches")">Versiyonlar</a> üzerinden kurulur; script eklerken seçtiğin klasöre doğrudan eklenir. Sürüm oluşturmak için <a href="@Url.Action("Index", "Releases")">Sürümler</a>.</p>
    </div>
    @if (canAuthor)
    {
        <div class="page-actions">
            <button type="button" class="btn btn-primary modern-btn text-white" onclick="openScriptsPageCreateModal()">Yeni script</button>
        </div>
    }
</div>

<div class="panel-card">
    <div class="panel-header">
        <h3>Script listesi</h3>
    </div>

    <div class="table-toolbar">
        <input id="scriptFilterInput" class="table-filter-input" placeholder="Script ara..." />
    </div>

    <div class="table-wrap custom-scroll">
        <table class="modern-table" id="scriptTable">
            <thead>
                <tr>
                    <th>Ad</th>
                    <th>Durum</th>
                    <th>Batch</th>
                    <th>Geliştirici</th>
                    <th>Rollback</th>
                    <th>Tarih</th>
                    <th></th>
                </tr>
            </thead>
            <tbody id="scriptTableBody">
                @foreach (var item in Model.Scripts)
                {
                    var canMarkReady = item.StatusEnum == ScriptStatus.Draft
                                       && (isAdmin || item.DeveloperId == actorUserId);
                    var statusBadgeCls = item.StatusEnum switch {
                        ScriptStatus.Ready    => "script-badge script-badge--ready",
                        ScriptStatus.Draft    => "script-badge script-badge--draft",
                        ScriptStatus.Conflict => "script-badge script-badge--conflict",
                        _                     => "script-badge"
                    };
                    <tr data-filter-hidden="0">
                        <td><a href="@Url.Action("Detail", "Scripts", new { id = item.ScriptId })" class="table-link">@item.Name</a></td>
                        <td>
                            <span class="@statusBadgeCls">@item.StatusDisplay</span>
                            @if (canMarkReady)
                            {
                                <button type="button" class="btn-inline-ready"
                                        onclick="markScriptReadyInline(@item.ScriptId, this)"
                                        title="Hazır olarak işaretle">✓</button>
                            }
                        </td>
                        <td>@item.BatchName</td>
                        <td>@item.DeveloperName</td>
                        <td>@(item.HasRollback ? "Var" : "—")</td>
                        <td>@item.CreatedAt.ToString("dd.MM.yyyy")</td>
                        <td class="text-nowrap">
                            <a class="btn btn-sm btn-table" href="@Url.Action("Detail", "Scripts", new { id = item.ScriptId })">Detay</a>
                            @if (AuthHelper.CanDeleteScript(User, item.DeveloperId))
                            {
                                <button type="button" class="btn btn-sm btn-outline-danger"
                                        onclick="deleteScriptFromList(@item.ScriptId, this)">Sil</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        window.__scriptsPageUrls = @Html.Raw(JsonSerializer.Serialize(new {
            createWizardContext = Url.Action("CreateWizardContext", "Scripts"),
            create = Url.Action("Create", "Scripts"),
            validateSql = Url.Action("ValidateSql", "Scripts"),
            changeStatus = Url.Action("ChangeStatus", "Scripts"),
            batchesIndex = Url.Action("Index", "Batches"),
            developerOptions = Url.Action("DeveloperOptions", "Scripts"),
            addPoolFolder = Url.Action("AddPoolFolder", "Batches"),
            treeChildren = Url.Action("TreeChildren", "Batches"),
            batchPath = Url.Action("BatchPath", "Batches"),
            detailUrlPlaceholder = Url.Action("Detail", "Scripts", new { id = 999999999L }),
            deleteUrlPlaceholder = Url.Action("Delete", "Scripts", new { id = 999999999L })
        }));
        window.__scriptCreateUrls = window.__scriptsPageUrls;
        setupTableFilter("scriptFilterInput", "#scriptTable tbody tr");
        setupPagination("scriptTableBody", 10);
    </script>
}
