@model ScriptManager.Models.Script.ScriptListItemViewModel
@using DAL.Enums
@{
    var canDelete = ViewBag.CanDelete as bool? == true;
    var actorRole = ViewBag.ActorRole as UserRole?;
    var actorUserId = ViewBag.ActorUserId as long? ?? 0L;
    var canStatus = ViewBag.CanChangeScriptStatus as bool? == true;
    var owns = Model.DeveloperId == actorUserId;
    var st = Model.StatusEnum;
    var canDraftActions = canStatus && st == ScriptStatus.Draft && (actorRole == UserRole.Admin || (actorRole == UserRole.Developer && owns));
    var canApproveReady = canStatus && st == ScriptStatus.Testing && actorRole == UserRole.Tester;
}

<div class="page-head">
    <div>
        <h1 class="page-title">@Model.Name</h1>
        <p class="page-subtitle">
            @Model.BatchName · @Model.DeveloperName · @Model.StatusDisplay · @Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")
        </p>
    </div>
    <div class="page-actions d-flex flex-wrap gap-2">
        @if (canDelete)
        {
            <button type="button" class="btn btn-outline-danger modern-btn" onclick="deleteScript(@Model.ScriptId)">Sil</button>
        }
        <a class="btn btn-light modern-btn" href="@Url.Action("Index", "Scripts")">← Script listesi</a>
    </div>
</div>

@if (Model.HasCacheBustHints)
{
    <div class="alert alert-warning d-flex align-items-start gap-2" role="alert">
        <span>⚠️</span>
        <div>
            <strong>Önbellek / plan riski ipuçları</strong>
            <div class="small mb-0">@Model.CacheBustSummary</div>
        </div>
    </div>
}

<div class="panel-card mb-4">
    <div class="panel-header">
        <h3 class="mb-0">Durum akışı</h3>
    </div>
    <div class="p-3">
        <p class="small text-muted mb-3 mb-md-2">
            Yeni kayıt <strong>Taslak</strong>tır. Geliştirici scripti <strong>İncelemede (test)</strong> durumuna alarak testçiye açar veya test gerekmiyorsa doğrudan <strong>Hazır</strong> yapar.
            <strong>Testçi</strong> incelemeden sonra <strong>Hazır</strong> onayını verir (yönetici bu adımı atlayamaz; ayrı bir testçi hesabı gerekir).
            <strong>Çakışma</strong> durumu aynı sürümde tablo örtüşmesi için sistem tarafından işaretlenir.
        </p>
        @if (st == ScriptStatus.Conflict)
        {
            <div class="alert alert-warning mb-0 py-2 small">Bu script çakışma kapsamında. Çakışmalar sayfasından inceleyip çözün veya metinleri güncelleyin; açık çakışma varken Hazır yapılamaz.</div>
        }
        else if (st == ScriptStatus.Ready)
        {
            <p class="mb-0 small text-success">Bu script <strong>hazır</strong> — paketleme ve sonraki adımlar için uygun.</p>
        }
        else if (canDraftActions || canApproveReady)
        {
            <div class="d-flex flex-wrap gap-2">
                @if (canDraftActions)
                {
                    <button type="button" class="btn btn-sm btn-outline-primary" onclick="changeScriptStatus(@Model.ScriptId, @((int)ScriptStatus.Testing))">Testçiye gönder (İncelemede)</button>
                    <button type="button" class="btn btn-sm btn-primary" onclick="changeScriptStatus(@Model.ScriptId, @((int)ScriptStatus.Ready))">Test atla — doğrudan Hazır</button>
                }
                @if (canApproveReady)
                {
                    <button type="button" class="btn btn-sm btn-success" onclick="changeScriptStatus(@Model.ScriptId, @((int)ScriptStatus.Ready))">Onayla — Hazır</button>
                }
            </div>
        }
        else
        {
            <p class="text-muted small mb-0">Bu durum için sizin rolünüzde işlem yok veya kayıt zaten güncel.</p>
        }
    </div>
</div>

<div class="content-grid single-column">
    <section class="panel-card">
        <div class="panel-header d-flex flex-wrap justify-content-between align-items-center gap-2">
            <h3 class="mb-0">SQL</h3>
            <button type="button" class="btn btn-sm btn-outline-primary"
                    onclick="downloadTextFile('@(Model.ScriptId)-script.sql', document.getElementById('sqlBlock').innerText)">
                .sql indir
            </button>
        </div>
        <pre id="sqlBlock" class="code-box">@Model.SqlScript</pre>
    </section>

    <section class="panel-card code-panel">
        <div class="panel-header d-flex flex-wrap justify-content-between align-items-center gap-2">
            <h3 class="mb-0">Rollback SQL</h3>
            @if (!string.IsNullOrWhiteSpace(Model.RollbackScript))
            {
                <button type="button" class="btn btn-sm btn-outline-secondary"
                        onclick="downloadTextFile('@(Model.ScriptId)-rollback.sql', document.getElementById('rbBlock').innerText)">
                    Rollback indir
                </button>
            }
        </div>
        @if (string.IsNullOrWhiteSpace(Model.RollbackScript))
        {
            <p class="text-muted mb-0 px-3 py-2">Rollback tanımlı değil.</p>
        }
        else
        {
            <pre id="rbBlock" class="code-box">@Model.RollbackScript</pre>
        }
    </section>
</div>

@section Scripts {
    <script>
        const __scriptChangeStatusUrl = "@Url.Action("ChangeStatus", "Scripts")";
        async function changeScriptStatus(scriptId, newStatus) {
            const res = await fetch(__scriptChangeStatusUrl, {
                method: "POST",
                headers: { "Content-Type": "application/json", Accept: "application/json" },
                body: JSON.stringify({ scriptId, newStatus })
            });
            let data = null;
            try {
                data = await res.json();
            } catch (_) {}
            if (!res.ok || data?.success === false) {
                showToast(data?.message || "Durum güncellenemedi.", "error");
                return;
            }
            showToast(data?.message || "Tamam.", "success");
            window.location.reload();
        }

        const __scriptDeleteUrl = "@Url.Action("Delete", "Scripts")";
        async function deleteScript(id) {
            if (!confirm("Bu script kalıcı olarak silinecek (durum: silindi). Emin misiniz?")) return;
            const res = await fetch(__scriptDeleteUrl + "/" + id, {
                method: "POST",
                headers: { Accept: "application/json" }
            });
            let data = null;
            try { data = await res.json(); } catch (_) {}
            if (!res.ok || !data?.success) {
                showToast(data?.message || "Silinemedi.", "error");
                return;
            }
            showToast(data?.message || "Silindi.", "success");
            window.location.href = "@Url.Action("Index", "Scripts")";
        }
    </script>
}
