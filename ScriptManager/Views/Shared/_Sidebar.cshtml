<div class="sidebar-brand">
    <div class="brand-logo">SM</div>
    <div class="brand-text">
        <strong>ScriptManager</strong>
        <span>Admin Panel</span>
    </div>
</div>

<nav class="sidebar-nav custom-scroll">
    <a class="nav-link-item @(ViewData["Title"]?.ToString() == "Dashboard" ? "active" : "")"
       href="@Url.Action("Index", "Dashboard")">
        <span>Dashboard</span>
    </a>

    <div class="nav-group">
        <button class="nav-collapse-btn" type="button" data-collapse-target="versionMenu">
            <span>Versions</span>
