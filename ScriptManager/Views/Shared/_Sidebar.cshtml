@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var user = ViewContext.HttpContext.User;
    var isAdmin = user.IsInRole("Admin");
}

<div class="sidebar-brand">
    <div class="brand-logo">SM</div>
    <div class="brand-text">
        <strong>ScriptManager</strong>
        <span>Sürüm Yönetimi</span>
    </div>
</div>

<nav class="sidebar-nav custom-scroll">
    <a class="nav-link-item @(currentController == "Dashboard" ? "active" : "")"
       href="@Url.Action("Index", "Dashboard")"
       data-tooltip="Genel istatistikler ve özet">Genel Bakış</a>

    <a class="nav-link-item @(currentController == "Releases" ? "active" : "")"
       href="@Url.Action("Index", "Releases")"
       data-tooltip="Prod'a aktarılacak sürümler">Sürümler</a>

    <a class="nav-link-item @(currentController == "Scripts" ? "active" : "")"
       href="@Url.Action("Index", "Scripts")"
       data-tooltip="SQL scriptlerin yönetimi">Scriptler</a>

    <a class="nav-link-item @(currentController == "Batches" ? "active" : "")"
       href="@Url.Action("Index", "Batches")"
       data-tooltip="Prod öncesi script paketleri">Versiyonlar</a>

    <a class="nav-link-item @(currentController == "Conflicts" ? "active" : "")"
       href="@Url.Action("Index", "Conflicts")"
       data-tooltip="Çakışan scriptlerin listesi">Çakışmalar</a>

    @if (isAdmin)
    {
        <a class="nav-link-item @(currentController == "Users" ? "active" : "")"
           href="@Url.Action("Index", "Users")"
           data-tooltip="Kullanıcı yönetimi">Kullanıcılar</a>
    }
</nav>

<div class="sidebar-footer">
    @* Giriş sonraya bırakıldı; oturum kapatma yok. *@
</div>