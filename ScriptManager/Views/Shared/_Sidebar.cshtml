        </button>

        <div id="versionMenu" class="nav-collapse-menu open">
            <a class="nav-sub-link" href="@Url.Action("Index", "Releases")">Releases</a>
        </div>
    </div>

    <a class="nav-link-item @(ViewData["Title"]?.ToString() == "Scripts" ? "active" : "")"
       href="@Url.Action("Index", "Scripts")">
        <span>Scripts</span>
    </a>

    <a class="nav-link-item" href="#">
        <span>Conflicts</span>
    </a>

    <a class="nav-link-item" href="#">
        <span>Users</span>
    </a>
