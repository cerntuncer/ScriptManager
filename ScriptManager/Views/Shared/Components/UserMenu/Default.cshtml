@model ScriptManager.ViewComponents.UserMenuViewModel

<div class="user-menu">
    <div class="user-avatar">@(Model.FullName.Length > 0 ? Model.FullName.Substring(0, 1) : "?")</div>
    <div class="user-meta">
        <div class="user-name">@Model.FullName</div>
        <div class="user-role">@Model.Role</div>
    </div>
</div>