@model ScriptManager.ViewComponents.UserMenuViewModel

@{
    var initial = Model.FullName.Length > 0 ? Model.FullName.Substring(0, 1).ToUpper() : "?";
    var isDev = string.IsNullOrEmpty(Model.Role) || Model.Role == "Giriş kapalı";
}

<div class="user-menu">
    <div class="user-avatar">@initial</div>
    @if (!isDev)
    {
        <div class="user-meta">
            <div class="user-name">@Model.FullName</div>
            <div class="user-role">@Model.Role</div>
        </div>
    }
</div>
