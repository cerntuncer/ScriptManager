@model int
@if (Model > 0)
{
    <a href="/Conflicts" class="icon-btn topbar-notify" title="@Model açık çakışma var" style="position:relative;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
        <span class="topbar-notify-badge">@(Model > 99 ? "99+" : Model.ToString())</span>
    </a>
}
else
{
    <button class="icon-btn" type="button" aria-label="Bildirimler" title="Bildirim yok">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
    </button>
}
